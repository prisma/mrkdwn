# All settings are optional in development.
#
# Workspace/page registry (Prisma Postgres, PostgreSQL >= 17).
# Leave unset in dev — the server auto-starts a local Prisma Postgres
# via @prisma/dev. Set it in production (e.g. your Prisma Postgres
# connection string).
# DATABASE_URL="postgresql://user:password@localhost:5432/mrkdwn"

# Durable storage: every page's full Automerge file is continually mirrored
# to S3 (coalesced, at most one write per doc per 2s). Any S3-compatible
# store works (Tigris, AWS, R2, MinIO). Unset → mirroring disabled.
# S3_ACCESS_KEY_ID="..."
# S3_SECRET_ACCESS_KEY="..."
# S3_BUCKET="mrkdwn"
# S3_ENDPOINT="https://t3.storage.dev"

# Public base URL, used in agent invite snippets (default: http://localhost:PORT)
# MRKDWN_BASE_URL="https://mrkdwn.example.com"

# Second origin serving /preview/* — HyperFrames compositions (arbitrary user
# HTML+JS) execute there, never on the app origin. Point a second hostname at
# the same server. Unset → dev fallback (localhost ↔ 127.0.0.1 swap).
# MRKDWN_PREVIEW_ORIGIN="https://preview.mrkdwn.example.com"

# Integrated Kimi agent for hyperframes pages (Moonshot API). Unset → hidden.
# KIMI_API_KEY="sk-..."
# KIMI_MODEL="kimi-k3"
# KIMI_BASE_URL="https://api.moonshot.ai/v1"

# HTTP + websocket port (default: 4545)
# PORT=4545

# Where server state lives: Automerge storage, agent token, notification
# queues (default: ./data)
# MRKDWN_DATA="./data"
